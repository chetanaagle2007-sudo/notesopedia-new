rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable helper primitives
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Notes collection rules
    match /notes/{noteId} {
      allow read: if true;
      allow create: if isValidId(noteId)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200
        && request.resource.data.content is string
        && request.resource.data.subjectName is string;
      allow update: if isValidId(noteId)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200;
      allow delete: if true;
    }

    // System configuration rules
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isValidId(configId);
    }
  }
}
